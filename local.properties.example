# Copy this file to local.properties and fill in real values.
# local.properties is git-ignored and must never be committed.

# Android SDK path (set automatically by Android Studio)
sdk.dir=/path/to/your/Android/sdk

# UmmahAPI — https://ummahapi.com/register
# Used for Quran verses, translation, audio, etc.
QURAN_API_KEY=your_ummahapi_key_here
QURAN_BASE_URL=https://ummahapi.com/api/
